{
  "$schema": "https://gofastmcp.com/public/schemas/fastmcp.json/v1.json",
  "source": {
    "type": "filesystem",
    "path": "src/modelark_mcp/server.py",
    "entrypoint": "mcp"
  },
  "environment": {
    "type": "uv",
    "python": ">=3.12",
    "dependencies": [
      "cachetools>=7.1.4,<8",
      "fastmcp>=3.4.4,<4.0",
      "httpx>=0.28.1,<1.0",
      "prometheus-client>=0.25.0,<1.0",
      "pydantic>=2.13.4,<3.0",
      "pydantic-settings>=2.14.2,<3.0",
      "starlette>=1.3.1,<2",
      "truststore>=0.10.4,<1.0"
    ]
  },
  "deployment": {
    "transport": "stdio",
    "log_level": "INFO"
  }
}
