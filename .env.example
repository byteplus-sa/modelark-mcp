# ============================================================================
# ModelArk Seed Multimodal MCP Server — environment template
#
# Copy this file to .env and fill in credentials. Provider credentials are
# startup configuration only and never tool arguments. If a credential is
# absent, the server must not register that product's tool set.
#
# See plans/PLAN_MODELARK_SEED_MULTIMODAL_MCP.md (Configuration Contract).
# ============================================================================

# --- Provider credentials (required) ---------------------------------------
# ModelArk data-plane key for Seedream (image) and Seedance (video).
# Region-scoped: must match BYTEPLUS_MODELARK_BASE_URL.
BYTEPLUS_MODELARK_API_KEY=

# Seed Speech key for Seed Audio (full-scene audio generation).
# Distinct from ModelArk; uses X-Api-Key, not Bearer.
BYTEPLUS_SEED_AUDIO_API_KEY=

# --- Provider base URLs ----------------------------------------------------
# ModelArk data-plane host. Default: ap-southeast region.
BYTEPLUS_MODELARK_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3

# Seed Speech host. Default: ap-southeast-1 region.
BYTEPLUS_SEED_AUDIO_BASE_URL=https://voice.ap-southeast-1.bytepluses.com

# --- Model bindings --------------------------------------------------------
# Bind logical families to account-authorized model/endpoint IDs.
# These are configuration, not hard-coded truth.
SEEDREAM_DEFAULT_MODEL=dola-seedream-5-0-pro-260628
SEEDANCE_DEFAULT_MODEL=dreamina-seedance-2-0-260128
# The built-in default IDs have known families. Any custom default ID must set
# a family or provide the JSON binding list below; names are never inferred.
# seedream: pro | lite | 4x
# seedance: standard | fast | mini
SEEDREAM_MODEL_FAMILY=
SEEDANCE_MODEL_FAMILY=
# JSON arrays for multiple explicitly authorized models, for example:
# SEEDREAM_MODEL_BINDINGS=[{"model_id":"my-image-endpoint","family":"pro"}]
# SEEDANCE_MODEL_BINDINGS=[{"model_id":"my-video-endpoint","family":"standard"}]
SEEDREAM_MODEL_BINDINGS=
SEEDANCE_MODEL_BINDINGS=

# --- MCP transport ---------------------------------------------------------
# stdio (default, local) or http (Streamable HTTP, remote deployment).
MCP_TRANSPORT=stdio
# Bind address for HTTP transport. 127.0.0.1 by default to prevent DNS rebinding.
MCP_HOST=127.0.0.1
MCP_PORT=3000
# Comma-separated allowed Origin values for HTTP transport. Empty = localhost only.
MCP_ALLOWED_ORIGINS=
# Comma-separated Host header values. Include the public hostname for remote use.
MCP_ALLOWED_HOSTS=127.0.0.1,localhost,[::1]

# local is accepted only for stdio or loopback HTTP. Network HTTP must use jwt.
MCP_AUTH_MODE=local
# Required together when MCP_AUTH_MODE=jwt.
MCP_JWT_JWKS_URI=
MCP_JWT_ISSUER=
MCP_JWT_AUDIENCE=
MCP_TENANT_CLAIM=tenant_id

# --- Artifact persistence --------------------------------------------------
# Filesystem is the currently implemented backend. Use a shared filesystem or
# implement a distributed backend before running multiple replicas.
ARTIFACT_BACKEND=filesystem
ARTIFACT_DIR=.artifacts
# Artifact retention TTL in seconds. Default: 7 days (604800).
ARTIFACT_TTL_SECONDS=604800
# Inline media cap for MCP image/audio content blocks. Default: 8 MiB.
MCP_INLINE_MEDIA_MAX_BYTES=8388608
# Maximum inbound Streamable HTTP request body. Default: 10 MiB.
MCP_HTTP_MAX_BODY_BYTES=10485760

# --- HTTP timeouts (milliseconds) ------------------------------------------
BYTEPLUS_CONNECT_TIMEOUT_MS=10000
# 5-minute request timeout covers long synchronous generations.
BYTEPLUS_REQUEST_TIMEOUT_MS=300000

# --- Runtime policy --------------------------------------------------------
PROVIDER_MAX_CONCURRENCY=5
PRINCIPAL_MAX_CONCURRENCY=3
# Per-principal UTC daily estimate limit in USD. 0 records without blocking.
DAILY_BUDGET_USD=0

# --- Logging ---------------------------------------------------------------
# Minimum log level for structured stderr logs: DEBUG | INFO | WARNING | ERROR
MODELARK_LOG_LEVEL=INFO
